# Database Configuration
DATABASE_URL=postgresql://meduser:medpass_dev@localhost:5432/medical_diagnosis
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Flask Configuration
FLASK_APP=backend/app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@medical-diagnosis.com

# ML Model Configuration
MODEL_PATH=models/model.pkl
SYMPTOM_COLUMNS_PATH=models/symptom_columns.pkl
VECTORIZER_PATH=models/vectorizer.pkl

# NLP Configuration
SPACY_MODEL=en_core_web_sm

# Rate Limiting
RATE_LIMIT_ANALYSIS=10 per hour
RATE_LIMIT_AUTOCOMPLETE=100 per minute
RATE_LIMIT_AUTH=5 per minute

# Session Configuration
SESSION_TIMEOUT=1800

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Report Configuration
REPORT_STORAGE_PATH=reports/
REPORT_EXPIRY_DAYS=30

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
