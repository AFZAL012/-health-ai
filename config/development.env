# Development Environment Configuration
FLASK_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql://meduser:medpass_dev@localhost:5432/medical_diagnosis

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS - Allow local development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Security (development keys - DO NOT use in production)
SECRET_KEY=dev-secret-key-change-me
JWT_SECRET_KEY=dev-jwt-secret-key-change-me

# Email (use console backend for development)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_BACKEND=console

# Disable some security features for easier development
CSRF_ENABLED=false
