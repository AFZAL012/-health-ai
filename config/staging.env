# Staging Environment Configuration
FLASK_ENV=staging
DEBUG=false
LOG_LEVEL=INFO

# Database - Use staging database
DATABASE_URL=postgresql://meduser:CHANGE_ME@staging-db-host:5432/medical_diagnosis_staging

# Redis - Use staging Redis
REDIS_URL=redis://staging-redis-host:6379/0

# CORS - Staging frontend URL
CORS_ORIGINS=https://staging.medical-diagnosis.com

# Security - Use strong keys from secrets management
SECRET_KEY=${STAGING_SECRET_KEY}
JWT_SECRET_KEY=${STAGING_JWT_SECRET_KEY}

# Email - Use real SMTP for staging
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=${STAGING_SMTP_USER}
SMTP_PASSWORD=${STAGING_SMTP_PASSWORD}

# Enable all security features
CSRF_ENABLED=true
HTTPS_ONLY=true
