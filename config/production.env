# Production Environment Configuration
FLASK_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# Database - Use production database with connection pooling
DATABASE_URL=postgresql://meduser:CHANGE_ME@prod-db-host:5432/medical_diagnosis
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis - Use production Redis cluster
REDIS_URL=redis://prod-redis-host:6379/0

# CORS - Production frontend URL only
CORS_ORIGINS=https://medical-diagnosis.com,https://www.medical-diagnosis.com

# Security - Use strong keys from secrets management (e.g., AWS Secrets Manager)
SECRET_KEY=${PROD_SECRET_KEY}
JWT_SECRET_KEY=${PROD_JWT_SECRET_KEY}

# Email - Production SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=${PROD_SMTP_USER}
SMTP_PASSWORD=${PROD_SMTP_PASSWORD}
SMTP_FROM=noreply@medical-diagnosis.com

# Enable all security features
CSRF_ENABLED=true
HTTPS_ONLY=true
SECURE_COOKIES=true

# Rate Limiting - Stricter in production
RATE_LIMIT_ANALYSIS=10 per hour
RATE_LIMIT_AUTOCOMPLETE=100 per minute
RATE_LIMIT_AUTH=3 per minute

# Monitoring
ENABLE_METRICS=true
SENTRY_DSN=${PROD_SENTRY_DSN}
